# Gemini AI Key (Get it from AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Port
PORT=3001

# Frontend URL (Update this for Vercel deployment)
FRONTEND_URL=http://localhost:5173

# MongoDB Connection String (Atlas or Local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/cuescreen?retryWrites=true&w=majority

# JWT Secret for Auth
JWT_SECRET=supersecretkey_change_this_for_prod

# Nodemailer Settings (Gmail with App Passwords)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password_here
